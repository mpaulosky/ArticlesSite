@* Add global render mode *@
@rendermode InteractiveServer

<CascadingAuthenticationState>
	<Router AppAssembly="typeof(Program).Assembly">
		<Found Context="routeData">
			<AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
				<NotAuthorized>
					<LayoutView Layout="typeof(MainLayout)">
						<ErrorPageComponent ErrorCode="403" ShadowColor="shadow-orange-500" TextColor="orange-600"></ErrorPageComponent>
					</LayoutView>
				</NotAuthorized>
				<Authorizing>
					<div class="main">Please wait...</div>
				</Authorizing>
			</AuthorizeRouteView>
		</Found>
		<NotFound>
			<LayoutView Layout="typeof(MainLayout)">
				<ErrorPageComponent ErrorCode="404" ShadowColor="shadow-yellow-500" TextColor="yellow-600"></ErrorPageComponent>
			</LayoutView>
		</NotFound>
	</Router>
</CascadingAuthenticationState>
